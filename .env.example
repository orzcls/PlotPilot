# aitext：Anthropic 兼容 API（与官方 SDK 一致；自建网关时设 BASE_URL）
# 与 Cursor「.claude/settings.json」里同名项对齐时，请复制到系统环境或本文件，勿提交密钥。
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=

# 与 aivideo 共用方舟凭证
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL=doubao-seed-2-0-mini-260215
ARK_TIMEOUT=120
ARK_REASONING_EFFORT=medium
# 代理 TLS 问题时直连
# ARK_NO_PROXY=1

# 可选默认篇幅
# AITEXT_DEFAULT_CHAPTERS=5
# AITEXT_DEFAULT_WORDS_PER_CHAPTER=2500
# AITEXT_SUMMARY_MAX_CHAPTERS=5

# ── Embedding Service Configuration ──
# Mode: 'openai' (cloud, lightweight) or 'local' (requires ~2GB download)
EMBEDDING_SERVICE=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
# Local model path (only used when EMBEDDING_SERVICE=local)
EMBEDDING_MODEL_PATH=./.models/bge-small-zh-v1.5
# GPU acceleration for local model (true/false)
EMBEDDING_USE_GPU=true

# ── Vector Store Configuration ──
VECTOR_STORE_TYPE=chromadb

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/aitext.log

# ── 桌面版（Tauri）数据目录 ──
# 生产构建下由 Rust 自动注入，指向用户可写目录（如 Windows: AppData\Roaming\com.plotpilot.app\data）
# 本地 CLI / 未设置时仍使用仓库内 data/
# AITEXT_PROD_DATA_DIR=

# 仅 Tauri 开发调试：设为 1 时即使在 debug 构建也注入 AITEXT_PROD_DATA_DIR（便于测 AppData）
# AITEXT_FORCE_PROD_DATA=0

# 关闭窗口时由 Tauri 调用 POST http://127.0.0.1:<port>/internal/shutdown（仅本机回环），无需手动配置
